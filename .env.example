# === Application ===
APP_FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# === Serveur ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# === Base de données (admin — utilisé par les scripts d'init/migrate) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=memoria_db_dev
DB_USER=postgres
DB_PASSWORD='remplace_par_npm_run_gen:secrets'

# === Base de données (compte applicatif — utilisé par l'API en runtime) ===
DB_APP_USER=app_memoria
DB_APP_PASSWORD='remplace_par_npm_run_gen:secrets'

# === Connection string (utilisée par DatabaseConnection) ===
DATABASE_URL='postgresql://app_memoria:DB_APP_PASSWORD_VALUE@localhost:5432/memoria_db_dev'
DB_SSL=false
DB_POOL_MAX=10

# === Auth (jose / JWT) ===
JWT_ACCESS_SECRET='remplace_par_npm_run_gen:secrets'
JWT_REFRESH_SECRET='remplace_par_npm_run_gen:secrets'
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
