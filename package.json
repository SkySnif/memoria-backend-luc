{
  "name": "memoria-api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "author": {
    "name": "wisepanda.fr",
    "email": "contact@wisepanda.fr"
  },
  "packageManager": "pnpm@10.30.2",
  "license": "MIT",
  "description": "API REST - Coffre-fort numérique personnel (Deuxième Cerveau)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "start:prod": "node --env-file=.env.prod dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "tsx --env-file=.env src/database/migrations/runAll.ts",
    "db:migrate:prod": "tsx --env-file=.env.prod src/database/migrations/runAll.ts",
    "db:nuke": "tsx --env-file=.env src/database/migrations/nukeAll.ts",
    "db:nuke:prod": "tsx --env-file=.env.prod src/database/migrations/nukeAll.ts",
    "db:init": "sh ./scripts/init_db.sh",
    "db:reset": "sh ./scripts/reset_db.sh",
    "db:run": "sh ./scripts/run_sql.sh",
    "gen:secrets": "tsx ./scripts/gen-secrets.ts",
    "gen:secrets:prod": "tsx ./scripts/gen-secrets.ts --prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^3.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^9.39.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@scarf/scarf"
    ]
  }
}
