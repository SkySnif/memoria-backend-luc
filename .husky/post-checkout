#!/usr/bin/env sh
# Git Hook: post-checkout — validates branch names on checkout

# Only validate on branch switches ($3 = 1)
[ "$3" = "1" ] || exit 0

BRANCH=$(git rev-parse --abbrev-ref HEAD)

case "$BRANCH" in
  main|develop|master|HEAD) exit 0 ;;
esac

PATTERN="^(feature|fix|hotfix|docs|style|refactor|perf|test|build|ci|chore|release)/[a-z0-9][a-z0-9-]*[a-z0-9]$"

if ! echo "$BRANCH" | grep -qE "$PATTERN"; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "❌ INVALID BRANCH NAME: $BRANCH"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "📖 REQUIRED FORMAT: <type>/<description>"
  echo "   Types: feature, fix, hotfix, docs, style, refactor, perf,"
  echo "          test, build, ci, chore, release"
  echo "   Description: lowercase, hyphens only, no start/end hyphen"
  echo ""
  echo "✅ Examples:"
  echo "   feature/auth-module"
  echo "   fix/login-redirect"
  echo "   chore/upgrade-pnpm"
  echo ""
  echo "🔧 Rename:"
  echo "   git branch -m $BRANCH <type>/<description>"
  echo ""
  exit 1
fi

echo "✅ Valid branch name: $BRANCH"
exit 0
